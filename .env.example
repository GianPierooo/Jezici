# Jezici · variables de entorno (PLANTILLA — sin secretos)
# Copia este archivo a .env y rellena los valores reales.
# .env está en .gitignore: NUNCA se comitea.

# Proyecto Supabase
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co

# Claves de API del proyecto (Settings → API en el panel de Supabase)
SUPABASE_ANON_KEY=your-anon-key                  # cliente (público), respeta RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # SERVIDOR ONLY · ignora RLS · nunca en el cliente
SUPABASE_PUBLISHABLE_KEY=your-publishable-key     # nueva gen. de clave pública
SUPABASE_SECRET_KEY=your-secret-key               # nueva gen. de clave secreta (servidor)

# Token de acceso personal de la Supabase CLI / Management API
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
