# ── Secretos / entorno ───────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ── Supabase ─────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/.env

# ── Node / herramientas ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Flutter / Dart (cuando arranque la app) ──────────────────────────
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
*.iml

# ── SO / editores ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Python cache (tools)
__pycache__/
*.pyc

# Content QA working artifacts (regenerables)
tools/content/_*

# codebase-memory-mcp: el grafo vive en ~/.cache/codebase-memory-mcp (por máquina),
# NO en el repo; reindexar es <1s. Defensivo por si una versión futura escribe aquí.
.codebase-memory/
tools/content/_lex0/
tools/content/_lex1/
tools/content/_lexpt/
tools/content/_lexfr/
tools/content/_lexde/
tools/content/_lexit/
tools/content/_lexnl/
