# Config pública de Supabase para la app Flutter (PLANTILLA, sin secretos).
# Copiar a app/.env y rellenar. La anon key es pública por diseño (RLS protege
# los datos); las llaves SECRETAS nunca van en el cliente.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # recomendada (nueva gen.)
SUPABASE_ANON_KEY=your-anon-key               # fallback (legacy)
